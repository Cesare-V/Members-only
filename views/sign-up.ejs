<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <title>Registrati</title>
</head>
<body>
  <h1>Crea un account</h1>

  <% if (errors.length > 0) { %>
    <ul>
      <% errors.forEach(err => { %>
        <li style="color:red"><%= err.msg %></li>
      <% }) %>
    </ul>
  <% } %>

  <form action="/sign-up" method="POST">
    <label>Nome: <input type="text" name="first_name" /></label><br>
    <label>Cognome: <input type="text" name="last_name" /></label><br>
    <label>Email: <input type="email" name="email" /></label><br>
    <label>Password: <input type="password" name="password" /></label><br>
    <label>Conferma password: <input type="password" name="confirm_password" /></label><br>
    <label>Password admin (opzionale): <input type="text" name="admin_secret" /></label><br>
    <button type="submit">Registrati</button>
  </form>

  <a href="/">Torna alla home</a>
</body>
</html>